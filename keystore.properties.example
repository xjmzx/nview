# Release signing credentials for the Android build.
#
# Copy this file to `keystore.properties` (which is gitignored) and fill in
# your values. `android/app/build.gradle` reads it automatically; when it's
# absent the release build stays unsigned (debug builds are unaffected).
#
# Generate an upload keystore once:
#   keytool -genkeypair -v -keystore ndisc-view.jks \
#     -alias ndisc-view -keyalg RSA -keysize 2048 -validity 10000
#
# Keep the .jks and this file OUT of git. For CI, store the keystore as a
# base64 secret and the passwords as secrets (see .github/workflows/release.yml).
#
# storeFile is resolved relative to `android/app/`, so a relative path is
# fragile — use an ABSOLUTE path to the .jks to avoid surprises.

storeFile=/absolute/path/to/ndisc-view.jks
storePassword=CHANGE_ME
keyAlias=ndisc-view
keyPassword=CHANGE_ME
